% aten.sty

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{aten}[My LaTeX Style]

% Core packages
\usepackage{titling} % to make title, etc sans-serif
\usepackage{tocloft} % to make ToC sans-serif
\usepackage{amsmath, amsthm, amssymb}
\usepackage[most]{tcolorbox}
\usepackage{graphicx}
\usepackage{fancyhdr}
\usepackage{geometry}
\usepackage{hyperref}
\usepackage{titlesec}
\usepackage{xcolor}
\usepackage{parskip}
\usepackage{multicol}
\usepackage[shortlabels]{enumitem}
\usepackage[outline]{contour} % for bolding sans-serif
\contourlength{0.1pt}
\usepackage[nottoc]{tocbibind} % Add ToC, LoF, LoT to ToC

% \usepackage[sfdefault]{noto-sans}
\usepackage[T1]{fontenc}

% \setlength{\parindent}{0pt} % DISALES AUTO-INDENTING
% \setlength{\parskip}{0.5em plus 0.5em minus 0.2em}

% Make tags use default font
\makeatletter
\def\tagform@#1{\maketag@@@{\textrm{(\ignorespaces#1\unskip\@@italiccorr)}}}
\makeatother

\usepackage{etoolbox}
\AtBeginEnvironment{proof}{\vspace*{-\parskip}}
\AtEndEnvironment{proof}{%
  \noindent
}

% Geometry: Margin customization
\geometry{top=3cm, bottom=3cm, left=3cm, right=3cm}

% Header setup
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0.4pt}
\setlength{\headheight}{13.6pt}
\addtolength{\topmargin}{-1.6pt}

% Footer setup
\fancyfoot[C]{\thepage}
\renewcommand{\footrulewidth}{0pt}

% Colors
\definecolor{crimson}{HTML}{BF0040}
\definecolor{airfblue}{HTML}{0073C0}

% Hyperref setup for clickable links
\hypersetup{
    colorlinks=true,
    linkcolor=airfblue,
    citecolor=green,
    urlcolor=cyan,
}

% Number equations, figures, and tables by section
\numberwithin{equation}{section}
\numberwithin{figure}{section}
\numberwithin{table}{section}
\setcounter{tocdepth}{2}

\setlength{\cftpartindent}{0em}
\setlength{\cftsecindent}{3.0em}
\setlength{\cftsubsecindent}{4.5em}

% title, etc sans-serif

\pretitle{\begin{center}\huge\bfseries\sffamily\contour{black}}
\posttitle{\par\end{center}\vskip 0.5em}

\preauthor{\begin{center}\large\sffamily}
\postauthor{\par\end{center}}

\predate{\begin{center}\large\sffamily}
\postdate{\par\end{center}}

% TOC sans-serif

\renewcommand{\cfttoctitlefont}{\normalfont\Large\bfseries\sffamily}

\renewcommand{\cftpartfont}{\sffamily\bfseries}
\renewcommand{\cftpartpagefont}{\sffamily\bfseries}

\renewcommand{\cftsecfont}{\sffamily\bfseries}
\renewcommand{\cftsecpagefont}{\sffamily\bfseries}

\renewcommand{\cftsubsecfont}{\sffamily}
\renewcommand{\cftsubsecpagefont}{\sffamily}

% Part setup
\titleformat{\part}[display]
  {\normalfont\Huge\bfseries\sffamily\raggedright}
  {\color{crimson} Part \thepart}
  {0.1em}
  {\fontsize{50}{60}\selectfont\contour{black}}

% Section setup
\titleformat{\section}
  {\normalfont\Large\bfseries\sffamily}
  {\color{crimson}\S\thesection}
  {0.5em}
  {\contour{black}}

% Subsection setup
\titleformat{\subsection}
  {\normalfont\large\bfseries\sffamily}
  {\color{crimson}\S\thesubsection}
  {0.5em}
  {\contour{black}}

% ---- Custom Styles for Theorem Environments ----
\tcbset{
  commonstyle/.style={
    enhanced,
    breakable,
    sharp corners,
    boxrule=0pt,
    frame hidden,
    borderline west={3pt}{0pt}{tcbcolframe}, 
    colback=gray!5!white,
    fonttitle=\bfseries\color{tcbcolframe},
    attach title to upper,
    after title={:\enskip},
    left=10pt,
    right=5pt,
    top=5pt,
    bottom=5pt,
    before skip=0.5em,
    after skip=0.5em,
  },
  theoremstyle/.style={commonstyle, colframe=green!30!black},
  definitionstyle/.style={commonstyle, colframe=brown!60!black},
  remarkstyle/.style={commonstyle, colframe=orange!50!black},
  examplestyle/.style={commonstyle, colframe=purple!60!black}
}

% ---- Environments ----

\setlist[description]{
    labelwidth=3cm,
    leftmargin=!,
    align=right,
    font=\bfseries
}

\newcommand{\todo}[1][]{%
  \,\tcbox[
    on line,
    arc=2pt,
    colback=green!60!black,
    colframe=green!60!black,
    coltext=white,
    boxsep=0pt,
    left=3pt,
    right=3pt,
    top=2pt,
    bottom=2pt,
    boxrule=0pt
  ]{\texttt{TODO}}
  \ifstrempty{#1}{}{ \texttt{#1}}%
\,}

% ---- Theorem Environments ----

% Master theorem counter, reset every section
\newtheorem{theorem}{Theorem}[section]


% -- Upright --
\newtheoremstyle{upright}
  {\parskip}
  {}
  {\upshape}
  {}
  {\bfseries}
  {.}
  {.5em}
  {}

\theoremstyle{upright}
\newtheorem{simplethm}[theorem]{Theorem}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{corollary}[theorem]{Corollary}
\newtheorem{observation}[theorem]{Observation}
\newtheorem{lemma}[theorem]{Lemma}

% Other environments share the theorem counter
\newtheorem{definitionbox}[theorem]{Definition}
\newtheorem{remark}[theorem]{Remark}
\newtheorem{example}[theorem]{Example}
\newtheorem{problem}[theorem]{Problem}

\makeatletter
\let\c@figure\c@theorem
\makeatother

% Numbering format
\renewcommand{\thetheorem}{\thesection.\arabic{theorem}}
\renewcommand{\thedefinition}{\thetheorem}
\renewcommand{\theremark}{\thetheorem}
\renewcommand{\theexample}{\thetheorem}
\renewcommand{\theproblem}{\thetheorem}

\renewenvironment{theorem}[1][]{%
  \refstepcounter{theorem}% % Changed
  \begin{tcolorbox}[theoremstyle, title={Theorem \thetheorem\ifx\relax#1\relax\else~\normalfont\small(#1\small)\fi}]%
}{\end{tcolorbox}}

\renewenvironment{definitionbox}[1][]{%
  \refstepcounter{theorem}%
  \begin{tcolorbox}[definitionstyle, title={Definition \thetheorem\ifx\relax#1\relax\else~\normalfont\small(#1\small)\fi}]%
}{\end{tcolorbox}}

\renewenvironment{remark}[1][]{%
  \refstepcounter{theorem}%
  \begin{tcolorbox}[remarkstyle, title={Remark \thetheorem\ifx\relax#1\relax\else~\normalfont\small(#1\small)\fi}]%

}{\end{tcolorbox}}

\renewenvironment{example}[1][]{%
  \refstepcounter{theorem}%
  \begin{tcolorbox}[examplestyle, title={Example \thetheorem\ifx\relax#1\relax\else~\normalfont\small(#1\small)\fi}]%
}{\end{tcolorbox}}

\renewenvironment{problem}[1][]{%
  \refstepcounter{theorem}%
  \begin{tcolorbox}[title={Problem \thetheorem\ifx\relax#1\relax\else~\normalfont\small(#1\small)\fi}]%
}{\end{tcolorbox}}


% ---- NEW ENVIRONMENTS ----
% arg must be passed as {}
\newenvironment{mitemize}[1]
{
 \begin{multicols}{#1}
 \begin{itemize}[leftmargin=*, nosep]
}
{
 \end{itemize}
 \end{multicols}
}

